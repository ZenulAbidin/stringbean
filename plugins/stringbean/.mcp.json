{
  "mcpServers": {
    "stringbean": {
      "type": "stdio",
      "command": "/usr/bin/python3",
      "args": [
        "./mcp/server.py"
      ],
      "cwd": ".",
      "startup_timeout_sec": 10,
      "tool_timeout_sec": 30,
      "supports_parallel_tool_calls": false,
      "env_vars": [
        "XDG_CONFIG_HOME",
        "XDG_DATA_HOME",
        "XDG_CACHE_HOME",
        "CODEX_HOME",
        "STRINGBEAN_ACTIVE_CHILD",
        "CLAUDE_CONFIG_DIR",
        "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "XAI_API_KEY",
        "GROK_API_KEY"
      ],
      "default_tools_approval_mode": "auto",
      "enabled_tools": [
        "start_sbx",
        "poll_sbx",
        "cancel_sbx"
      ],
      "tools": {
        "start_sbx": {
          "approval_mode": "approve"
        }
      }
    }
  }
}
