#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
REPO_ROOT="$(cd -- "$PLUGIN_ROOT/../.." 2>/dev/null && pwd || true)"

if [[ -n "${STRINGBEAN_SBX:-}" ]]; then
  SBX="$STRINGBEAN_SBX"
elif [[ -n "$REPO_ROOT" && -x "$REPO_ROOT/scripts/sbx" ]]; then
  SBX="$REPO_ROOT/scripts/sbx"
elif command -v sbx >/dev/null 2>&1; then
  SBX="$(command -v sbx)"
else
  printf 'Stringbean sbx was not found. Install the local shim or set STRINGBEAN_SBX.\n' >&2
  exit 127
fi

ARGS=("$@")
HAS_OUTPUT_MODE=false
HAS_PROGRESS_INTERVAL=false

for arg in "${ARGS[@]}"; do
  case "$arg" in
    --plugin-full-output|--full-output|--plugin-compact-output|--plugin-live-output|--plugin-final|--codex-final)
      HAS_OUTPUT_MODE=true
      ;;
    --codex-progress-interval|--codex-progress-interval=*)
      HAS_PROGRESS_INTERVAL=true
      ;;
  esac
done

if [[ "$HAS_OUTPUT_MODE" == false ]]; then
  ARGS+=(--plugin-compact-output)
fi
if [[ "$HAS_PROGRESS_INTERVAL" == false ]]; then
  ARGS+=(--codex-progress-interval "${STRINGBEAN_PLUGIN_PROGRESS_INTERVAL:-5}")
fi

exec "$SBX" "${ARGS[@]}"
